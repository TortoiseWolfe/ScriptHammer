# ScriptHammer Environment Variables
# Copy this file to .env and fill in your values

# GitHub Personal Access Token (for API operations)
# Generate at: https://github.com/settings/tokens
# Required scopes: repo, workflow
GITHUB_TOKEN=

# Supabase Configuration
# Public Supabase URL (safe to expose in client code)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public Anon Key (safe to expose in client code - respects RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role Key (NEVER expose in client code - bypasses RLS)
# Only use in server-side code and Edge Functions
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Application URL (for auth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
