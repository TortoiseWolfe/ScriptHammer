# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (keep .env.example for documentation)
.env
.env.backup
.env.local
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright
test-results/
playwright-report/
tests/e2e/fixtures/storage-state-auth.json

# pnpm
.pnpm-store/

# Generated files (copied during build)
public/wireframes/
public/TASKS.md
public/manifest.json
/src/config/project-detected.ts
/src/config/project-detected.json
/public/rss.xml
/public/sitemap.xml

# Claude Code local settings (user-specific permissions)
.claude/settings.local.json

# Local Specify development tools (keep outputs, ignore scripts/templates)
.specify/scripts/
.specify/templates/
plan
tasks
storybook-static/

# SpecKit installed extensions — payload is reinstalled via `./specify
# extension add …`. We commit: the registry (`.specify/extensions.yml`) and
# any project-local `wireframe-config.yml`. We ignore everything else.
# Negation requires the parent pattern to match files (no trailing slash) so
# the !-rule below actually re-includes the config.
.specify/extensions/**
!.specify/extensions/
!.specify/extensions/*/
!.specify/extensions/*/wireframe-config.yml
.claude/skills/speckit-wireframe-*/

# Brainstorm scratch (superpowers visual-companion sessions)
.superpowers/
.component-backup-*
docs/visual-testing/

# Test screenshots
screenshots/
mobile-check.png

# Runtime test fixtures — created by node:test beforeEach, deleted by afterEach.
# If afterEach fails they linger; never commit them (see fixtures/README.md).
scripts/__tests__/fixtures/*
!scripts/__tests__/fixtures/README.md

# SpecKit wrapper (Docker-first) — tool + cache state, never commit
.speckit-tools/
.speckit-cache/
