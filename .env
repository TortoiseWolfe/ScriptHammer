# .env - Sample Environment Variables

# App configuration
APP_NAME=ScriptHammer
USE_THEME=Y           # Set to "Y" to enable theme fonts download, "N" to skip

# Supabase configuration
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Map service (if using Google Maps for the Map page)
EXPO_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY



EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=EXPO_PUBLIC_GOOGLE_MAPS_API_KEY

# Environment mode (optional)
NODE_ENV=development  # or "production" depending on your deployment
# NODE_ENV=production